import numpy as np

a = np.array([20, 30, 40, 50])
b = np.arange(4)

print("Array a:", a)
print("Array b:", b)

print("Addition:", a + b)
print("Subtraction:", a - b)
print("Multiplication:", a * b)
print("Division:", a / b)

print("b raised to power 4:", b ** 4)

print("10 * sin(a):", 10 * np.sin(a))

a[0] += 10

print("Modified a:", a)

print("Dot Product:", np.dot(a, b))
