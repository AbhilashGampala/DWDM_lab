import numpy as np

x = np.array([1, 2, 3])

print("Original Array:", x)

b = np.append(x, [6, 4, 2])
print("Array after adding elements:", b)

newarray = np.delete(x, 2)
print("Array after deleting element:", newarray)

c = np.array([6, 4, 1, 3, 5, 9])
print("Before Modification:", c)

c[c < 4] = -1

print("After Modification:", c)
